#!/usr/bin/env bash

export NIRI_SOCKET=${NIRI_SOCKET:-$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -name 'niri.*' -print -quit)}

theme_kind="${1:-$(darkman get)}"

echo "Switching to $theme_kind mode"

# Programs with first-party mode support.

kitten themes --cache-age=-1 --config-file-name=themes.conf --reload-in=all "Tilia ($theme_kind)"
makoctl mode -s "$theme_kind"

colour_scheme="$HOME/.local/share/color-schemes/Tilia ($theme_kind).colors"
accent_colour="$(kreadconfig6 --file "$colour_scheme" --group Colors:Window --key DecorationFocus)"
kwriteconfig6 --file kdeglobals --group General --key AccentColor "$accent_colour"

kwriteconfig6 --file kdeglobals --group General --key ColorScheme --delete
QT_QPA_PLATFORM=offscreen plasma-apply-colorscheme "Tilia ($theme_kind)"

# Manual theme switching.
ln -sf "$HOME/.config/git/delta-${theme_kind}.gitconfig" ~/.config/git/delta-theme.gitconfig
ln -sf "$HOME/.config/fuzzel/${theme_kind}.ini" ~/.config/fuzzel/fuzzel.ini
ln -sf "$HOME/.config/micro/colorschemes/${theme_kind}.micro" ~/.config/micro/colorschemes/current.micro
ln -sf "$HOME/.config/niri/${theme_kind}.kdl" ~/.config/niri/theme.kdl
ln -sf "$HOME/.config/swaylock/${theme_kind}" ~/.config/swaylock/config
ln -sf "$HOME/.config/waybar/${theme_kind}.css" ~/.config/waybar/colours.css

# Signal long running programs.
niri msg action load-config-file
killall --signal SIGUSR2 waybar

# Handle wallpapers.
~/.local/bin/switch-wallpaper

:
